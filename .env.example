# Database (PostgreSQL). Railway provides DATABASE_URL automatically.
DATABASE_URL=postgresql://user:password@localhost:5432/fitclaude

# JWT secret for auth tokens (use a long random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Anthropic API key for Claude
ANTHROPIC_API_KEY=sk-ant-...

# Server port (Railway sets PORT automatically)
PORT=3000
